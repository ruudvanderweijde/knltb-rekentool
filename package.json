{
  "name": "knltb-rekentool",
  "version": "1.0.0",
  "description": "KNLTB Padel Rekentool – webpagina + CLI voor DSS padel-ratingwijzigingen",
  "scripts": {
    "start": "node server.js",
    "proxy:dev": "npx wrangler dev --config proxy/wrangler.toml",
    "proxy:deploy": "npx wrangler deploy --config proxy/wrangler.toml",
    "test": "node --test 'tests/**/*.test.js'"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "playwright": "^1.59.1"
  }
}
