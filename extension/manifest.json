{
  "manifest_version": 3,
  "name": "KNLTB Padel Rekentool (onofficieel)",
  "version": "1.0.0",
  "description": "Bereken DSS padel-ratingwijzigingen per uitslag vanaf een mijnknltb head-2-head pagina. Onofficieel — gebruikt je eigen KNLTB-login; er wordt geen data verzameld.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "KNLTB Padel Rekentool — open een head-2-head pagina en klik op de knop",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "host_permissions": [
    "https://mijnknltb.toernooi.nl/*",
    "https://www.nlpadel.nl/*",
    "https://id.knltb.nl/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://mijnknltb.toernooi.nl/head-2-head*"],
      "js": ["shared.js", "content.js"],
      "css": ["modal.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["calculator/*"],
      "matches": ["https://mijnknltb.toernooi.nl/*"]
    }
  ]
}
